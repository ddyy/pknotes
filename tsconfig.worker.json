{
  // Worker (workerd runtime) code. Runtime + Env types come from
  // worker-configuration.d.ts, generated by `npm run cf-typegen`.
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": [],
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["worker", "worker-configuration.d.ts"],
  // Test files use the `cloudflare:test` / vitest modules, which are typed by
  // vitest's own tooling, not the worker runtime config. Type-check them there.
  "exclude": ["worker/**/*.test.ts", "worker/test-helpers.ts", "worker/test-setup.ts"]
}
